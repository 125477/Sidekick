{
  "name": "sidekick",
  "private": true,
  "version": "1.0.0",
  "license": "PolyForm-Noncommercial-1.0.0",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "dev:ui": "pnpm --filter ui dev",
    "build:ui": "pnpm --filter ui build",
    "pack:desktop": "pnpm build:ui && pnpm --filter @sidekick/electron-app run pack",
    "pack:desktop:mac": "pnpm build:ui && pnpm --filter @sidekick/electron-app run pack:mac",
    "pack:desktop:win": "pnpm build:ui && pnpm --filter @sidekick/electron-app run pack:win",
    "pack:desktop:all": "pnpm build:ui && pnpm --filter @sidekick/electron-app run pack:all",
    "lint:ui": "pnpm --filter ui lint"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
